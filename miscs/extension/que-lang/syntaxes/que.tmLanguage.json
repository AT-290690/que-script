{
  "scopeName": "source.que",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#macros" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#types" }
  ],
  "repository": {
    "comments": {
      "patterns": [{ "name": "comment.line.que", "match": ";.*$" }]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.que", "begin": "\"", "end": "\"" },
        { "name": "string.quoted.single.que", "begin": "'", "end": "'" }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.que",
          "match": "\\b(Int|Dec|Bool|Char)\\b"
        }
      ]
    },
    "macros": {
      "patterns": [
        {
          "name": "entity.name.function.macro.que",
          "match": "\\b(letmacro|quote|qq|uq|uqs|gensym|macroexpand|macroexpand-1)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.que",
          "match": "\\b(unless|when|when-not|cond|cons|while|alter|mut|do|let|let\\*|loop|if|lambda|mod|length|as|get|at|set|pop|push|pull|swap|emod|not|and|or|identity|eq|integer|fixed|boolean|variable|que|string|chars|digits|vector|bigint|tuple|table|fst|snd|car|cdr|has|in-bounds|apply|eq|comp|matrix|shell|Vector|String|Matrix|BigInt|Tuple|Table|Set|Hash|Que|Integer|Floating|Boolean|Heap|map|filter|reduce|every|some|select|exclude|find|sum|product|slice|take|drop|range|flat)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.que",
          "match": "\\b(true|false|nil|infinity)\\b"
        },
        {
          "name": "support.function.que",
          "match": "\\b(enumerate|nl|sp|ep|dq|sq|bt|empty|copy|reverse|sort|square|sqrt|expt|floor|ceil|max|min|abs|first|last|count|points|zip|unzip|permutation|window|pair|lcm|gcd|call|odd|even|upper|lower|match|digit|fill|clamp|one|zero|ones|zeroes|positive|negative|invert|divisible|maximum|minimum|for|subset|scan|extreme|neighborhood|unique|transpose|interleave|intersperse|cycle|replicate|avg|mean|median|each|const|group|append|tail|head|split|join|replace|list-dir|delete|mkdir|move|read|write|clear|print|sleep)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.que",
          "match": "(\\+|\\-|\\*|\\/|%=|\\=\\=|\\!\\=|\\>\\=|\\<\\=|\\&|\\||\\^|\\!|\\~|\\?|\\:|\\.|\\|\\>|\\+\\+|\\-\\-)"
        }
      ]
    },
    "numbers": {
      "patterns": [{ "name": "constant.numeric.que", "match": "\\b[0-9]+\\b" }]
    }
  }
}
